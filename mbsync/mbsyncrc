# isync/mbsync config — COHS Microsoft 365 via XOAUTH2.
#
# This file is symlinked to ~/.mbsyncrc via dotter.
#
# Prerequisites (macOS):
#   - mbsync (isync) built from upstream against Homebrew cyrus-sasl
#     with the cyrus-sasl-xoauth2 plugin installed. Installed at
#     ~/.local/bin/mbsync (takes PATH precedence over /opt/homebrew/bin).
#   - pizauth binary in ~/.local/bin/, stable-codesigned with identifier
#     `com.williamnapier.pizauth`. Daemon runs via launchd and holds OAuth
#     tokens in memory; `pizauth show cohs` prints a fresh access token
#     on stdout, refreshing automatically if expired.
#
# First-time setup (once per install):
#   pizauth refresh cohs   # triggers browser OAuth flow
#
# On Linux (nimbini): distribution package cyrus-sasl-xoauth2 drops the
# plugin into the system SASL dir; stock mbsync from the distro works
# out of the box. Same mbsyncrc contents. Same `pizauth refresh` step.

IMAPAccount cohs
Host outlook.office365.com
Port 993
User will.napier@changeofharleystreet.com
AuthMechs XOAUTH2
# PassCmd output is used as the SASL XOAUTH2 token. pizauth's daemon
# handles refresh transparently; the printed token is always fresh at
# the moment of use.
PassCmd "$HOME/.local/bin/pizauth show cohs"
SSLType IMAPS
# macOS trust store is used implicitly; no CertificateFile needed.

IMAPStore cohs-remote
Account cohs

MaildirStore cohs-local
Path ~/Mail/cohs/
Inbox ~/Mail/cohs/INBOX/
SubFolders Verbatim

# Sync all standard M365/Exchange folders. Pull-only: COHS IMAP is
# authoritative, local is a read-only mirror. If mutation from local-side
# Meli is wanted later, change `Sync Pull` to `Sync All`.
#
# Patterns list matches typical Exchange Online folder names. The `!`
# prefix excludes: we drop the "Conversation History", "RSS Subscriptions",
# "Outbox" and a few other Outlook-internal folders that typically contain
# nothing useful. Add more patterns (or `*` to catch everything) if
# additional folders appear over time.

Channel cohs-all
Far :cohs-remote:
Near :cohs-local:
Patterns "INBOX" "Sent Items" "Drafts" "Archive" "Deleted Items" "Junk Email"
Sync Pull
Expunge None
CopyArrivalDate yes
Create Near
SyncState *

# Historical single-INBOX channel, kept for explicit "just pull inbox" invocations.
Channel cohs-inbox
Far :cohs-remote:INBOX
Near :cohs-local:INBOX
Sync Pull
Expunge None
CopyArrivalDate yes
Create Near
SyncState *

# Convenience group so `mbsync cohs` syncs everything COHS-related.
Group cohs
Channel cohs-all

# --- Gmail spike (Oxidise Lieer project, restarted 2026-05-01) ---
#
# Parallel pull into ~/Mail/gmail-mb/ — does NOT touch lieer's
# ~/Mail/personal/. Initial Patterns is INBOX-only to bound the spike
# (Gmail's INBOX label, not All Mail — tens of MB, not 24 GB).
#
# Once the spike confirms (a) pizauth XOAUTH2 negotiates cleanly,
# (b) folder structure under [Gmail]/ is sane, (c) notmuch indexes
# the parallel maildir without confusing tags between lieer- and
# mbsync-sourced copies — the next iteration expands Patterns to
# `[Gmail]/All Mail` (the canonically-correct Gmail-IMAP source,
# avoiding the per-label-folder duplication footgun) and we plan
# the lieer→mbsync flip.
#
# First-time setup (once per install):
#   pizauth refresh gmail
# (already done on this machine — pizauth status shows Active.)
IMAPAccount gmail
Host imap.gmail.com
Port 993
User will@willnapier.com
AuthMechs XOAUTH2
PassCmd "$HOME/.local/bin/pizauth show gmail"
TLSType IMAPS

IMAPStore gmail-remote
Account gmail

MaildirStore gmail-local
Path ~/Mail/gmail-mb/
Inbox ~/Mail/gmail-mb/INBOX/
SubFolders Verbatim

Channel gmail-spike
Far :gmail-remote:
Near :gmail-local:
# Phase 2 (2026-05-01 17:22): expanded from INBOX-only to include
# [Google Mail]/All Mail — Gmail's canonical "every message exactly
# once" folder. UK English variant is "Google Mail" not "Gmail";
# probed via mbsync -l 17:24 — `[Gmail]/...` matches NOTHING on this
# account, `[Google Mail]/...` is correct. ~24GB / 218k-message pull
# on first run. INBOX kept in Patterns during transition; eventual
# cleanup will drop it (every Inbox message also exists under All
# Mail, so the local INBOX/ directory becomes redundant once All Mail
# is fully synced).
Patterns "INBOX" "[Google Mail]/All Mail"
Sync Pull
Expunge None
CopyArrivalDate yes
Create Near
SyncState *

Group gmail
Channel gmail-spike
