#!/usr/bin/env nu

# Syncthing Connection Monitor - Keep the local daemon available
#
# Syncthing already retries peer connections itself. In particular, mobile peers
# are expected to be offline for long periods. Restarting the local daemon merely
# because any peer is disconnected can therefore turn a harmless offline phone
# into a complete Mac <-> nimbini outage.

def main [] {
    let log_file = $"($env.HOME)/.local/share/syncthing-monitor.log"
    let api_key = get_syncthing_api_key

    if ($api_key | is-empty) {
        log_error "Failed to get Syncthing API key"
        exit 1
    }

    # Ensure log directory exists
    mkdir ($log_file | path dirname)

    log_info "🔍 Starting Syncthing connection monitor"
    log_info $"📊 API Key: ($api_key | str substring 0..8)..."
    log_info $"📝 Logging to: ($log_file)"

    loop {
        let status = check_connections $api_key

        if not $status.api_reachable {
            log_error "Syncthing API is unavailable; restarting the local service"
            restart_local_service
            sleep 30sec  # Give the daemon time to start and expose its API
        } else if ($status.disconnected | length) > 0 {
            # Peer availability is informational. Syncthing owns reconnection;
            # never bounce the healthy local daemon for an offline peer.
            log_warning $"Offline devices; no restart: ($status.disconnected | str join ', ')"
        } else {
            log_info $"✅ All devices connected: ($status.connected | str join ', ')"
        }

        sleep 5min  # Check every 5 minutes
    }
}

# Get Syncthing API key from config
def get_syncthing_api_key [] {
    try {
        # Syncthing v2 follows XDG state-directory conventions on Linux. Keep
        # the legacy path last so upgraded and older installations both work.
        let config_path = ([
            $"($env.HOME)/Library/Application Support/Syncthing/config.xml"
            $"($env.HOME)/.local/state/syncthing/config.xml"
            $"($env.HOME)/.config/syncthing/config.xml"
        ] | where {|path| $path | path exists } | first)

        open --raw $config_path |
        lines |
        where {|l| $l | str contains "apikey"} |
        first |
        str trim |
        parse "<apikey>{key}</apikey>" |
        get key.0
    } catch {
        ""
    }
}

# Check connection status of all devices
def check_connections [api_key: string] {
    try {
        let connections = http get $"http://localhost:8384/rest/system/connections" --headers [X-API-Key $api_key]
        let devices = $connections.connections | columns

        let connected = $devices | where {|device|
            ($connections.connections | get $device | get connected) == true
        }

        let disconnected = $devices | where {|device|
            ($connections.connections | get $device | get connected) == false
        }

        {
            api_reachable: true,
            connected: $connected,
            disconnected: $disconnected
        }
    } catch {
        log_error "Failed to check connections - Syncthing may be down"
        {
            api_reachable: false,
            connected: [],
            disconnected: []
        }
    }
}

# Restart only when the local API itself is unavailable. Do this through the
# platform service manager; the REST restart endpoint cannot help when the API is
# down and, with Homebrew's --no-restart flag, intentionally exits with code 3.
def restart_local_service [] {
    let result = if $nu.os-info.name == "macos" {
        let domain = $"gui/((id -u | str trim))/homebrew.mxcl.syncthing"
        (launchctl kickstart -k $domain | complete)
    } else {
        (systemctl --user restart syncthing.service | complete)
    }

    if $result.exit_code == 0 {
        log_info "✅ Local Syncthing service restart requested"
    } else {
        log_error $"❌ Local Syncthing service restart failed: ($result.stderr | str trim)"
    }
}

# Logging functions
def log_info [message: string] {
    let timestamp = (date now | format date "%Y-%m-%d %H:%M:%S")
    let log_entry = $"[($timestamp)] INFO: ($message)"
    print $log_entry
    $log_entry | save --append $"($env.HOME)/.local/share/syncthing-monitor.log"
}

def log_warning [message: string] {
    let timestamp = (date now | format date "%Y-%m-%d %H:%M:%S")
    let log_entry = $"[($timestamp)] WARN: ($message)"
    print $log_entry
    $log_entry | save --append $"($env.HOME)/.local/share/syncthing-monitor.log"
}

def log_error [message: string] {
    let timestamp = (date now | format date "%Y-%m-%d %H:%M:%S")
    let log_entry = $"[($timestamp)] ERROR: ($message)"
    print $log_entry
    $log_entry | save --append $"($env.HOME)/.local/share/syncthing-monitor.log"
}
