#!/usr/bin/env bash
# email — open MailForge (the daily-driver MUA) in the browser (macOS).
#
# Triggered by Hammerspoon's Cmd+Shift+Return rule (~/dotfiles/hammerspoon/init.lua).
# May also be run by hand at a shell prompt. The Linux equivalent (same name)
# lives at ~/dotfiles/scripts/email-linux and deploys to the same ~/.local/bin/email.
#
# MailForge runs as a launchd daemon (com.williamnapier.mailforge) serving a
# Leptos browser MUA on http://127.0.0.1:8765 (CoHS M365 + personal Gmail in one
# client). "Open email" = make sure the daemon + mail sync are live, then open
# the UI in the default browser.
#
# History: this launcher previously opened the meli TUI in WezTerm and kicked the
# long-retired com.user.mail-sync (lieer) agent. Repointed to MailForge 2026-06-10;
# meli is still available by running `meli` directly.

# Ensure the MailForge daemon is up (kickstart is idempotent fire-and-forget).
launchctl kickstart "gui/$UID/com.williamnapier.mailforge" 2>/dev/null

# Kickstart the live sync agents for fresh mail:
#   gmpull      = canonical Gmail puller (Gmail REST API)
#   mbsync-cohs = COHS (M365) IMAP via XOAUTH2
# (mbsync-gmail is deliberately NOT kicked — gmpull is the canonical Gmail path.)
launchctl kickstart "gui/$UID/com.williamnapier.gmpull" 2>/dev/null
launchctl kickstart "gui/$UID/com.williamnapier.mbsync-cohs" 2>/dev/null

# Open the MailForge UI (307-redirects to the inbox) in the default browser.
open "http://127.0.0.1:8765"
