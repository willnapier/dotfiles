#!/usr/bin/env bash
# email — open meli in a fresh WezTerm window (macOS).
# Linux equivalent (same name) lives at ~/dotfiles/scripts/email-linux,
# which dotter deploys to the same ~/.local/bin/email path on nimbini.
#
# Triggered by Karabiner's Cmd+Shift+Return rule (per
# ~/dotfiles/karabiner/karabiner.json complex_modifications). May also
# be invoked by hand at a shell prompt.
#
# Absolute path to /opt/homebrew/bin/wezterm: ~/.local/bin/wezterm is a
# symlink to the .app's wezterm CLI, but the CLI spawns a sibling
# `wezterm-gui` from the same directory and ~/.local/bin/ has no such
# sibling. Always invoke the brew-managed location which has both.
#
# `default_prog` override: wezterm.lua sets default_prog = nushell, so
# the trailing `-- meli` arg after `start` is ignored (config-level
# default wins). Setting default_prog per-invocation via --config
# (Lua array syntax — curly braces, NOT JSON brackets) tells THIS
# wezterm to launch meli as its default program.
#
# `--always-new-process` ensures a fresh wezterm process tree rather
# than routing into an existing wezterm mux. The fresh process gives
# the macOS Window Server a foreground requestor, so the new window
# can come to front (per the Karabiner-spawn HID context).
#
# Idempotency: pkill any existing meli first. meli's notmuch backend
# caches per-row tag state at query time and doesn't refresh tags on
# already-listed rows when Ctrl+R fires — only new arrivals get fresh
# tags. So a long-lived meli accumulates stale tag chips. Pre-killing
# means one keypress = one fresh meli, regardless of prior state.
# WezTerm's default exit_behavior=CloseOnCleanExit closes the old
# window automatically once meli has exited.
pkill -x meli 2>/dev/null
exec /opt/homebrew/bin/wezterm \
  --config 'default_prog={"/opt/homebrew/bin/meli"}' \
  start \
  --always-new-process
