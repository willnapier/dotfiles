#!/usr/bin/env bash
# email — open meli in a maximized Ghostty window (macOS)
#
# Uses Ghostty's native --maximize flag. Result: fresh Ghostty window
# filling the screen (but not entering macOS fullscreen-Space mode),
# running meli. Other Ghostty windows are untouched.
#
# Why `open -na`: on macOS, Ghostty is a .app bundle; launching with flags
# from outside Terminal requires `open -na Ghostty.app --args ...`.

exec open -na Ghostty.app --args --maximize=true -e meli
