#!/usr/bin/env bash
# email — open meli in a maximized Ghostty window (macOS)
#
# Uses Ghostty's native AppleScript dictionary to create a new window
# running meli INSIDE the existing Ghostty process. This keeps the meli
# window part of the same app/process as your other Ghostty terminals,
# so Cmd+` window-cycling includes it.
#
# Design history:
# - v1: --maximize=true flag via open -na — flag didn't reach Ghostty reliably
# - v2: drop -n, zoom via menu — meli didn't launch (existing Ghostty ignores -e)
# - v3: restore -n, PID-diff for zoom — works, but spawns separate process
#   so Cmd+` doesn't see the meli window
# - v4 (this): Ghostty AppleScript API — creates a surface configuration with
#   the meli command, opens new window in existing process, zooms via
#   System Events targeting the (now unambiguous) ghostty process
#
# Requires Accessibility permission for AppleScript (one-time prompt).

set -e

# 1. Create a surface configuration with meli as the command, then open
#    a new Ghostty window using it. This all happens inside the existing
#    Ghostty process.
osascript <<'EOF'
tell application "Ghostty"
  activate
  set cfg to new surface configuration
  set command of cfg to "meli"
  new window with configuration cfg
end tell
EOF

# 2. Wait for the window to appear and become frontmost
sleep 1.0

# 3. Zoom the frontmost Ghostty window by setting its bounds.
#    Since there's only one Ghostty process now, "process ghostty" is
#    unambiguous, and the newly-created window is the frontmost one.
osascript <<'EOF'
tell application "Finder"
  set screenBounds to bounds of window of desktop
end tell
set screenWidth to item 3 of screenBounds
set screenHeight to item 4 of screenBounds

tell application "System Events"
  tell process "ghostty"
    tell window 1
      set position to {0, 25}
      set size to {screenWidth, screenHeight - 25}
    end tell
  end tell
end tell
EOF
