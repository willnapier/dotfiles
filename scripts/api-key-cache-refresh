#!/bin/bash
# api-key-cache-refresh — refresh the cached API keys used by nushell env.nu.
#
# macOS `security find-generic-password` takes ~8s per hit on this machine
# due to permanent SEP/Secure-Enclave IPC degradation (kernel extension damage
# from a now-removed VPN client). Calling it at every shell startup made new
# terminal windows hang for ~20s. This script reads the keys once and writes
# them to a TOML cache that env.nu loads instantly.
#
# Run after rotating any of the cached keys:
#   gemini-api-key / forgepodium
#   openai-api-key / semantic-search
#
# Works on macOS (keychain via `security`) and Linux (gnome-keyring via
# `secret-tool`). The cache file is chmod 600.

set -euo pipefail

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/shell"
CACHE_FILE="$CACHE_DIR/api-keys.toml"

mkdir -p "$CACHE_DIR"

fetch_darwin() {
    local service="$1" account="$2"
    security find-generic-password -s "$service" -a "$account" -w 2>/dev/null || printf ''
}

fetch_linux() {
    local service="$1" account="$2"
    if command -v secret-tool >/dev/null 2>&1; then
        secret-tool lookup service "$service" account "$account" 2>/dev/null || printf ''
    else
        printf ''
    fi
}

case "$(uname -s)" in
    Darwin)
        GEMINI=$(fetch_darwin "gemini-api-key" "forgepodium")
        OPENAI=$(fetch_darwin "openai-api-key" "semantic-search")
        ;;
    Linux)
        GEMINI=$(fetch_linux "gemini-api-key" "forgepodium")
        OPENAI=$(fetch_linux "openai-api-key" "semantic-search")
        ;;
    *)
        echo "api-key-cache-refresh: unsupported OS $(uname -s)" >&2
        exit 1
        ;;
esac

umask 077
TMP=$(mktemp "${CACHE_FILE}.XXXXXX")
{
    echo "# Auto-generated by api-key-cache-refresh. Do not edit."
    echo "# Rotate a key then re-run: api-key-cache-refresh"
    printf 'gemini_api_key = "%s"\n' "$GEMINI"
    printf 'openai_api_key = "%s"\n' "$OPENAI"
} > "$TMP"
chmod 600 "$TMP"
mv "$TMP" "$CACHE_FILE"

echo "Cached API keys to $CACHE_FILE"
