#!/usr/bin/env bash
# mail-status-watch — single-line live indicator of last mail sync timestamps.
#
# Polls every 30 s and rewrites the current Zellij tab name to e.g.
#   "📧 ws 07:48 · cohs 07:43"
# Designed to be backgrounded inside a Zellij pane (so `zellij action
# rename-tab` targets the right tab — it inherits ZELLIJ_* env vars from
# the parent pane). The companion wrapper `meli-with-status` does that
# backgrounding when launched via the `email-meli` layout.
#
# Sources of truth:
#   workspace (lieer/Gmail): last "DONE" line in ~/.local/share/mail-sync.log
#   cohs (mbsync, Darwin):   ~/Library/Logs/mbsync-cohs.log mtime — mbsync
#                            has no embedded timestamps so file mtime is the
#                            freshest signal of a successful sync run.
#   cohs (mbsync, Linux):    systemctl --user show -p ExecMainStartTimestamp
#                            (NOT ActiveEnterTimestamp — oneshot units that
#                            fail never reach the "active" state, so that
#                            property stays empty after a PassCmd failure).

set -u

WORKSPACE_LOG="$HOME/.local/share/mail-sync.log"
PLATFORM="$(uname -s)"
EMPTY="—"

last_workspace() {
    [ -f "$WORKSPACE_LOG" ] || { echo "$EMPTY"; return; }
    local ts
    ts="$(awk '$3=="DONE"{ts=$2} END{print ts}' "$WORKSPACE_LOG")"
    if [ -n "$ts" ]; then
        echo "${ts:0:5}"
    else
        echo "$EMPTY"
    fi
}

last_cohs() {
    case "$PLATFORM" in
        Darwin)
            local f="$HOME/Library/Logs/mbsync-cohs.log"
            [ -f "$f" ] || { echo "$EMPTY"; return; }
            stat -f '%Sm' -t '%H:%M' "$f"
            ;;
        Linux)
            local ts
            ts="$(systemctl --user show mbsync-cohs.service -p ExecMainStartTimestamp --value 2>/dev/null)"
            # "Sun 2026-04-26 15:53:26 BST" → 15:53
            if [ -n "$ts" ] && [ "$ts" != "0" ] && [ "$ts" != "n/a" ]; then
                echo "$ts" | awk '{print $3}' | cut -c1-5
            else
                echo "$EMPTY"
            fi
            ;;
        *)
            echo "$EMPTY"
            ;;
    esac
}

while :; do
    ws="$(last_workspace)"
    cohs="$(last_cohs)"
    zellij action rename-tab "📧 ws ${ws} · cohs ${cohs}" >/dev/null 2>&1 || true
    sleep 30
done
