#!/usr/bin/env bash
# meli-with-status — entry command for the email-meli Zellij layout.
# Runs mail-status-watch in the background (which polls last sync times and
# updates the Zellij tab name every 30 s), then runs meli in the foreground.
# When meli exits, the watcher is killed via the EXIT trap.
set -u

# Self-contained PATH: zellij-spawned processes don't always inherit a
# usable PATH. From WezTerm's `--always-new-process` flow the inherited
# env can be the launchd/Apple minimal set, and ~/.profile only adds
# homebrew (not ~/.local/bin/). Setting PATH here keeps the layout
# `bash -lc meli-with-status` working regardless of how the parent
# terminal was launched.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

mail-status-watch &
WATCHER=$!
trap 'kill "$WATCHER" 2>/dev/null || true' EXIT INT TERM

meli "$@"
