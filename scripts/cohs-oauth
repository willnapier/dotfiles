#!/usr/bin/env bash
# Portable wrapper: invoke cohs-oauth.py via the cohs-auth venv.
# Works on macOS and Linux — $HOME resolves correctly on both.
# The venv itself is not dotfile-tracked (binary artifacts per-machine);
# see CLI-EMAIL-SYSTEM.md "New machine setup" for how to create it.
exec "$HOME/.config/cohs-auth/venv/bin/python3" "$HOME/dotfiles/scripts/cohs-oauth.py" "$@"
