#!/usr/bin/env nu
# Smart prev/next navigation for Helix via Zellij keystroke injection.
# Usage: hx-day-nav <prev|next> [buffer_name]
#
# Dispatch by buffer location:
#   - Rust Book chapter (~/rust-learning/book/src/ch*.md) → previous/next chapter
#   - Otherwise                                            → previous/next DayPage
#
# In both cases, sends `:open <path><Enter>` to Helix via Zellij keystrokes.

def main [direction: string, buffer_name?: string] {
    let book_dir = $"($env.HOME)/rust-learning/book/src"

    # Debug log — inspect with: open /tmp/hx-day-nav.log
    $"[(date now | format date '%H:%M:%S')] dir=($direction) buffer=($buffer_name)\n" | save -a /tmp/hx-day-nav.log

    # Dispatch by buffer basename. The book pane's CWD is book/src, so
    # Helix's %{buffer_name} arrives as a bare basename like
    # `ch01-00-getting-started.md` — a `starts-with absolute-path` check
    # never matches. Match on the chapter-file naming pattern instead;
    # that scopes navigation to the rust-learning context without needing
    # Zellij session detection.
    let basename = if ($buffer_name != null) { $buffer_name | path basename } else { "" }
    let is_book_file = ($basename =~ '^ch\d+')

    let target_path = if $is_book_file {
        book-nav $direction $basename $book_dir
    } else {
        daypage-nav $direction $buffer_name
    }

    # Expose target for other consumers
    $target_path | save -f /tmp/helix-day-target.txt

    # Inject :open command into Helix via Zellij
    # write 27 = Escape (ensure NORMAL mode); write 13 = Enter
    sleep 200ms
    ^zellij action write 27
    sleep 100ms
    ^zellij action write-chars $":open ($target_path)"
    sleep 100ms
    ^zellij action write 13
}

# Sequential navigation through the main Rust Book chapters (ch*.md).
# Lexicographic order matches reading order because chapters use
# zero-padded NN-NN numbering (ch01-00, ch01-01, ch01-02, ch02-00...).
# Appendices and front-matter are reachable via SUMMARY.md + gf.
def book-nav [direction: string, buffer_name: string, book_dir: string] {
    let chapters = (ls ($"($book_dir)/ch*.md" | into glob) | get name | each { path basename } | sort)
    let current = ($buffer_name | path basename)
    let matches = ($chapters | enumerate | where item == $current)
    let current_idx = if ($matches | is-empty) { 0 } else { ($matches | first | get index) }
    let last_idx = (($chapters | length) - 1)
    let target_idx = if $direction == "next" {
        [($current_idx + 1), $last_idx] | math min
    } else {
        [($current_idx - 1), 0] | math max
    }
    $"($book_dir)/" + ($chapters | get $target_idx)
}

def daypage-nav [direction: string, buffer_name?: string] {
    # Extract date from buffer name if it looks like a DayPage
    let current_date = if ($buffer_name != null) {
        let basename = ($buffer_name | path basename | str replace '.md' '')
        if ($basename =~ '^\d{4}-\d{2}-\d{2}$') {
            $basename | into datetime
        } else {
            date now
        }
    } else {
        date now
    }

    let target_date = if $direction == "prev" {
        $current_date - 1day | format date "%Y-%m-%d"
    } else {
        $current_date + 1day | format date "%Y-%m-%d"
    }

    let note_path = $"($env.HOME)/Forge/NapierianLogs/DayPages/($target_date).md"

    # Create from template if DayPage doesn't exist
    if not ($note_path | path exists) {
        let result = (do { daypage-template $target_date } | complete)
        if $result.exit_code == 0 and ($result.stdout | str trim | is-not-empty) {
            $result.stdout | save -f $note_path
        }
    }

    $note_path
}
