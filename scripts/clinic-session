#!/usr/bin/env bash
# clinic-session — Interactive clinical note-writing session with Gemma voice model
# The Product prototype: Gemma only, no other AI in the loop.
# Works on both Mac and Linux (nushell-safe: called via bash shebang)

set -euo pipefail

EDITOR="${EDITOR:-hx}"
OLLAMA_PORT="11434"
SESSION_START=$(date +%s)
CLIENTS_DONE=()
SESSION_DATE=$(date +%Y-%m-%d)

# --- Colours ---
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Pre-flight: check inference tunnel ---
preflight() {
    printf "${DIM}Checking inference tunnel...${NC} "
    local response
    response=$(curl -s --max-time 3 "http://localhost:$OLLAMA_PORT/api/tags" 2>/dev/null || true)
    if echo "$response" | python3 -c "import sys,json; json.load(sys.stdin)" &>/dev/null; then
        local models
        models=$(echo "$response" | python3 -c "
import sys,json
models = json.load(sys.stdin).get('models',[])
names = [m['name'].split(':')[0] for m in models]
print(', '.join(names))
")
        echo -e "${GREEN}connected${NC} (${models})"
        return 0
    else
        echo -e "${RED}not connected${NC}"
        echo ""
        echo "Run 'inference-start' first to open the SSH tunnel to the inference server."
        exit 1
    fi
}

# --- Get observation via editor ---
get_observation() {
    local client_id="$1"
    local tmpfile
    tmpfile=$(mktemp /tmp/clinic-obs-XXXXXX.md)

    # Pre-populate with a hint
    cat > "$tmpfile" << EOF
# Observation for $client_id — $(date +%Y-%m-%d)
# Write your session observation below, then save and quit.
# Lines starting with # are stripped before sending to the model.

EOF

    $EDITOR "$tmpfile"

    # Strip comment lines and leading/trailing whitespace
    local obs
    obs=$(grep -v '^#' "$tmpfile" | sed '/^[[:space:]]*$/d' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
    rm -f "$tmpfile"

    if [ -z "$obs" ]; then
        return 1
    fi

    echo "$obs"
}

# --- Generate note via Gemma ---
generate_note() {
    local client_id="$1"
    local observation="$2"
    local tmpnote
    tmpnote=$(mktemp /tmp/clinic-note-XXXXXX.md)

    echo -e "${DIM}Generating...${NC}"
    local start_time
    start_time=$(date +%s)

    # clinical note --no-save outputs the note to stdout
    clinical note "$client_id" "$observation" --no-save > "$tmpnote" 2>/dev/null

    local end_time elapsed
    end_time=$(date +%s)
    elapsed=$((end_time - start_time))
    echo -e "${DIM}(${elapsed}s)${NC}"
    echo ""

    cat "$tmpnote"
    echo ""

    # Return path to temp file for later use
    echo "$tmpnote"
}

# --- Review loop ---
review_note() {
    local client_id="$1"
    local observation="$2"
    local notefile="$3"

    while true; do
        echo -e "${BOLD}[A]ccept / [E]dit / [R]e-generate / [S]kip?${NC} "
        read -r -n 1 choice
        echo ""

        case "${choice,,}" in
            a)
                # Save via clinical note-save
                cat "$notefile" | clinical note-save "$client_id" 2>&1
                echo -e "${GREEN}✓ Saved${NC}"

                # Mark attended in DayPage
                daypage-mark-done "$client_id" 2>/dev/null && \
                    echo -e "${GREEN}✓ Marked $client_id attended${NC}" || true

                CLIENTS_DONE+=("$client_id")
                rm -f "$notefile"
                return 0
                ;;
            e)
                # Open note in editor for manual edits
                $EDITOR "$notefile"
                echo ""
                echo -e "${DIM}--- Edited note ---${NC}"
                cat "$notefile"
                echo -e "${DIM}---${NC}"
                echo ""
                # Loop back to accept/edit/etc
                ;;
            r)
                rm -f "$notefile"
                echo -e "${DIM}Re-opening editor for observation...${NC}"
                local new_obs
                new_obs=$(get_observation "$client_id") || { echo "Empty observation, skipping."; return 1; }

                local output
                output=$(generate_note "$client_id" "$new_obs")
                # Last line of output is the temp file path
                notefile=$(echo "$output" | tail -1)
                # Print everything except the last line (the note content)
                echo "$output" | head -n -1
                echo ""
                observation="$new_obs"
                ;;
            s)
                echo -e "${YELLOW}Skipped $client_id${NC}"
                rm -f "$notefile"
                return 1
                ;;
            *)
                echo "Choose: a/e/r/s"
                ;;
        esac
    done
}

# --- End of session ---
end_session() {
    local session_end
    session_end=$(date +%s)
    local duration_min=$(( (session_end - SESSION_START) / 60 ))
    local client_count=${#CLIENTS_DONE[@]}

    echo ""
    echo -e "${BOLD}=== Session complete ===${NC}"

    if [ "$client_count" -eq 0 ]; then
        echo "No clients documented."
        return
    fi

    local client_list
    client_list=$(IFS=', '; echo "${CLIENTS_DONE[*]}")
    echo "Clients: $client_list ($client_count)"
    echo "Duration: ${duration_min} min"

    # Queue DayPage entry
    local entry="clinical-notes:: ${client_count} clients ${duration_min}min - ${client_list}"
    echo ""
    echo -e "${DIM}Queuing: $entry${NC}"
    daypage-append "$entry" 2>/dev/null && \
        echo -e "${GREEN}✓ DayPage entry queued${NC}" || \
        echo -e "${YELLOW}⚠ daypage-append failed — queue manually${NC}"

    # Offer attendance report
    echo ""
    echo -e "Run attendance report for ${SESSION_DATE}? [y/n] "
    read -r -n 1 run_report
    echo ""
    if [ "${run_report,,}" = "y" ]; then
        clinic-attendance-report --date "$SESSION_DATE" 2>&1 && \
            echo -e "${GREEN}✓ Report saved${NC}" || \
            echo -e "${RED}✗ Report failed${NC}"
    fi
}

# --- Main ---
echo -e "${BOLD}=== Clinic Session ===${NC}"
echo -e "${DIM}Date: $SESSION_DATE${NC}"
preflight
echo ""

while true; do
    echo -e -n "${BOLD}Client ID${NC} (or 'done'): "
    read -r client_id

    # Exit conditions
    if [ -z "$client_id" ] || [ "$client_id" = "done" ] || [ "$client_id" = "q" ]; then
        break
    fi

    # Check client file exists
    local_file="$HOME/Clinical/clients/$client_id/$client_id.md"
    if [ ! -f "$local_file" ]; then
        echo -e "${RED}Client file not found: $local_file${NC}"
        echo "Check the ID and try again."
        echo ""
        continue
    fi

    # Get observation
    echo -e "${DIM}Opening editor for observation...${NC}"
    observation=$(get_observation "$client_id") || { echo "Empty observation, skipping."; echo ""; continue; }

    # Generate note
    output=$(generate_note "$client_id" "$observation")
    # Last line is the temp file path
    notefile=$(echo "$output" | tail -1)
    # Print everything except the last line
    echo "$output" | head -n -1

    # Review
    review_note "$client_id" "$observation" "$notefile" || true
    echo ""
done

end_session
