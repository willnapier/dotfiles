#!/usr/bin/env nu
# messageboard-edit - Atomic MESSAGEBOARD.md editing
# Bypasses Claude Code Edit tool's race condition by using direct file operations
#
# Usage: messageboard-edit insert "message content"
#        messageboard-edit remove-section "### 2026-01-11 — device"
#        messageboard-edit refresh-header
#        messageboard-edit show

# Trigger an immediate Syncthing rescan so a new/removed entry reaches the
# other machine without waiting for the periodic scan. Best-effort: a sync
# failure must never break the edit. This is the producer-side equivalent of
# the old PostToolUse "sync on MESSAGEBOARD edit" hook, which can no longer
# fire now that raw Edit/Write to MESSAGEBOARD.md is blocked (messageboard-guard).
def trigger-sync [] {
    try {
        let key = (syncthing cli config gui apikey get | str trim)
        if not ($key | is-empty) {
            ^curl -s -X POST $"http://127.0.0.1:8384/rest/db/scan?folder=Assistants" -H $"X-API-Key: ($key)" | ignore
        }
    } catch { }
}

def main [action: string, content?: string] {
    let file = $"($env.HOME)/Assistants/shared/MESSAGEBOARD.md"
    let device = (sys host | get hostname)
    let date = (date now | format date "%Y-%m-%d")

    match $action {
        "insert" => {
            if ($content | is-empty) {
                print "Error: message content required"
                return
            }

            # Read current content
            let current = (open $file)

            # Find insertion point (after "## Messages" line)
            let lines = ($current | lines)
            let insert_idx = ($lines | enumerate | where {|x| $x.item == "## Messages"} | first | get index) + 1

            # Build new message
            let header = $"### ($date) — ($device)"
            let new_message = $"($header)\n\n($content)\n\n---\n"

            # Insert message
            let before = ($lines | first ($insert_idx + 1) | str join "\n")
            let after = ($lines | skip ($insert_idx + 1) | str join "\n")
            let updated = $"($before)\n\n($new_message)\n($after)"

            # Write atomically
            $updated | save -f $file
            trigger-sync
            print $"✅ Message inserted into MESSAGEBOARD.md at ($date) — ($device)"
        }

        "remove-section" => {
            if ($content | is-empty) {
                print "Error: section header required (e.g., '### 2026-01-11 — mac')"
                return
            }

            let current = (open $file)
            let lines = ($current | lines)

            # Find the section start
            let start_idx = try {
                $lines | enumerate | where {|x| $x.item | str starts-with $content} | first | get index
            } catch {
                print $"Section not found: ($content)"
                return
            }

            # Find next section (next ### or end)
            let end_idx = try {
                let remaining = ($lines | skip ($start_idx + 1) | enumerate)
                let next = ($remaining | where {|x| $x.item | str starts-with "###"} | first | get index)
                $start_idx + 1 + $next
            } catch {
                $lines | length
            }

            # Also remove the --- before the section if present
            let actual_start = if $start_idx > 0 and ($lines | get ($start_idx - 1)) == "---" {
                $start_idx - 1
            } else {
                $start_idx
            }

            # Reconstruct without the section
            let before = ($lines | first $actual_start | str join "\n")
            let after = ($lines | skip $end_idx | str join "\n")
            let updated = $"($before)\n($after)"

            $updated | save -f $file
            trigger-sync
            print $"✅ Removed section: ($content)"
        }

        "remove-containing" => {
            # Remove section that contains a specific string (for duplicate headers)
            if ($content | is-empty) {
                print "Error: search string required"
                return
            }

            let current = (open $file)
            let lines = ($current | lines)

            # Find line containing the unique string
            let match_idx = try {
                $lines | enumerate | where {|x| $x.item | str contains $content} | first | get index
            } catch {
                print $"No section containing: ($content)"
                return
            }

            # Find the section header (### line) before this match
            let start_idx = try {
                $lines | first $match_idx | enumerate | where {|x| $x.item | str starts-with "###"} | last | get index
            } catch {
                print "Could not find section header"
                return
            }

            # Find next section (next ### after match or end)
            let end_idx = try {
                let remaining = ($lines | skip ($match_idx + 1) | enumerate)
                let next = ($remaining | where {|x| $x.item | str starts-with "###"} | first | get index)
                $match_idx + 1 + $next
            } catch {
                $lines | length
            }

            # Also remove the --- before the section if present
            let actual_start = if $start_idx > 0 and ($lines | get ($start_idx - 1)) == "---" {
                $start_idx - 1
            } else {
                $start_idx
            }

            # Reconstruct without the section
            let before = ($lines | first $actual_start | str join "\n")
            let after = ($lines | skip $end_idx | str join "\n")
            let updated = $"($before)\n($after)"

            $updated | save -f $file
            trigger-sync
            print $"✅ Removed section containing: ($content)"
        }

        "refresh-header" => {
            let current = (open $file)
            let old = "> **Usage**: This header persists. Messages below get cleared by the\n> receiving assistant once addressed (action taken, information noted,\n> or question resolved). 30-day fallback for stale items. Newest at top.\n> Format: `### YYYY-MM-DD — device`"
            let new = "> **Usage**: This header persists. Ordinary inbox messages below get\n> cleared by the responsible receiver once addressed (action taken, information\n> noted, or question resolved). **Design-forum pointers are attention gateways,\n> not per-assistant inbox tasks:** follow them to `design-forum/INDEX.md`; do not\n> clear them merely because one assistant has participated. Retire or supersede\n> them only when they no longer point to relevant open forum work. 30-day\n> fallback applies to stale ordinary items. Newest at top.\n> Format: `### YYYY-MM-DD — device`"

            if not ($current | str contains $old) {
                print "Messageboard usage header is already current or has changed; no edit made"
                return
            }

            let updated = ($current | str replace $old $new)
            $updated | save -f $file
            trigger-sync
            print "✅ Refreshed MESSAGEBOARD.md usage header"
        }

        "show" => {
            open $file | print
        }

        _ => {
            print "Usage:"
            print "  messageboard-edit insert \"message\""
            print "  messageboard-edit remove-section \"### 2026-01-11 — device\""
            print "  messageboard-edit refresh-header"
            print "  messageboard-edit show"
        }
    }
}
