#!/usr/bin/env bash
# email — open meli in a WezTerm window on Linux/niri. Deployed to
# ~/.local/bin/email via [linux.files] so the command name matches
# the macOS launcher.
#
# --always-new-process: ensures a fresh WezTerm GUI (not the mux daemon).
# gui-startup skips its default shell window when cmd is non-nil (see
# wezterm.lua), so only the meli window appears.
#
# Idempotency: pkill any existing meli first. meli's notmuch backend
# caches per-row tag state at query time and doesn't refresh tags on
# already-listed rows when Ctrl+R fires — only new arrivals get fresh
# tags. Pre-killing means one keypress = one fresh meli regardless of
# prior state. WezTerm's default exit_behavior=CloseOnCleanExit closes
# the old window once meli has exited.
pkill -x meli 2>/dev/null

# Kickstart both sync units in parallel with meli launch.
# --no-block returns immediately; units run in their own systemd env.
# notmuch is updated by the time the user gets to the first Ctrl+R
# inside meli (or by the next launch).
systemctl --user start --no-block mail-sync.service mbsync-cohs.service 2>/dev/null

exec wezterm start --always-new-process -- meli
