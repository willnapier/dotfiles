#!/usr/bin/env bash
# email — open meli in a WezTerm window on Linux/niri. Deployed to
# ~/.local/bin/email via [linux.files] so the command name matches
# the macOS launcher.
#
# --always-new-process: ensures a fresh WezTerm GUI (not the mux daemon).
# gui-startup skips its default shell window when cmd is non-nil (see
# wezterm.lua), so only the meli window appears.
exec wezterm start --always-new-process -- meli
