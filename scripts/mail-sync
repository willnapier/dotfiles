#!/usr/bin/env bash
# mail-sync — periodic bidirectional Gmail sync via lieer + notmuch indexing
# Runs as launchd (macOS) or systemd timer (Linux)
# Safe to run frequently; idempotent, network-aware, locking built into gmi
#
# Design principle (2026-04-21): local actions should be first-class.
# When you tag a message in meli / notmuch, that action should actually
# reach Gmail without a manual push step. So this script does the full
# round trip: pull remote → index → push local → done.

set -euo pipefail

LOG="$HOME/.local/share/mail-sync.log"
MAIL_DIR="$HOME/Mail/personal"
NOTMUCH_CONFIG="$HOME/Mail/.notmuch-config"
export NOTMUCH_CONFIG

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG"
}

# Network check — skip silently if offline
# Use curl rather than ping (ping may not be in launchd PATH, and some hosts block ICMP)
if ! /usr/bin/curl -s --max-time 5 -o /dev/null https://www.google.com; then
    log "SKIP: network unreachable"
    exit 0
fi

# Ensure mail directory exists
if [ ! -f "$MAIL_DIR/.gmailieer.json" ]; then
    log "ERROR: lieer not initialized in $MAIL_DIR"
    exit 1
fi

# Resolve gmi — check venv symlink and PATH
GMI="$HOME/.local/bin/gmi"
if [ ! -x "$GMI" ]; then
    GMI="$(command -v gmi 2>/dev/null || true)"
    if [ -z "$GMI" ]; then
        log "ERROR: gmi not found"
        exit 1
    fi
fi

# Pull new messages
# Use --resume so interrupted initial syncs continue rather than restart
cd "$MAIL_DIR"
if [ -f ".resume-pull.gmailieer.json" ]; then
    log "START: gmi pull --resume (resuming interrupted pull)"
    PULL_ARGS="--resume"
else
    log "START: gmi pull"
    PULL_ARGS=""
fi
if "$GMI" pull $PULL_ARGS >> "$LOG" 2>&1; then
    log "OK: gmi pull complete"
else
    log "ERROR: gmi pull failed (exit $?)"
    exit 1
fi

# Index with notmuch
log "START: notmuch new"
if notmuch new >> "$LOG" 2>&1; then
    log "OK: notmuch new complete"
else
    log "ERROR: notmuch new failed (exit $?)"
    exit 1
fi

# Push local tag changes back to Gmail.
#
# 2026-04-22 migration: `gmi push` retired here in favour of the Rust
# `practiceforge email gmail-push-tags --push` path, which runs as its
# own launchd agent `com.williamnapier.gmail-push-tags` (15 min interval)
# and queries notmuch's lastmod against the same ~/Mail/personal/ index
# that lieer populates. The two scripts coexist cleanly: mail-sync pulls
# + indexes, gmail-push-tags pushes.
#
# Leaving lieer's `gmi push` fallback disabled rather than deleting the
# code because if push-tags is ever unloaded, we want a clear signal in
# the log rather than silent non-syncing. To re-enable, flip PUSH_VIA_GMI
# below.
PUSH_VIA_GMI="${PUSH_VIA_GMI:-0}"
if [ "$PUSH_VIA_GMI" = "1" ]; then
    log "START: gmi push (fallback — push-tags via Rust is disabled)"
    if "$GMI" push >> "$LOG" 2>&1; then
        log "OK: gmi push complete"
    else
        log "WARN: gmi push failed (exit $?) — will retry next tick"
    fi
else
    log "SKIP: gmi push (handled by practiceforge gmail-push-tags agent)"
fi

log "DONE"
