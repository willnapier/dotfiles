#!/usr/bin/env bash

# Syncthing Sync Watchdog
# Detects when file sync between Mac and Nimbini has stalled
#
# How it works:
# 1. Writes current timestamp to a heartbeat file in Forge
# 2. Polls Nimbini for that exact heartbeat
# 3. Alerts if it has not propagated within one minute
#
# Run via launchd every 5 minutes

set -euo pipefail

HEARTBEAT_FILE="$HOME/Forge/.syncthing-heartbeat-mac"
PROPAGATION_TIMEOUT_SECONDS=60
POLL_INTERVAL_SECONDS=5
LOG_FILE="$HOME/Library/Logs/syncthing-watchdog.log"
NIMBINI_HOST="will@nimbini"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG_FILE"
}

alert() {
    local msg="$1"
    log "ALERT: $msg"
    # macOS notification
    osascript -e "display notification \"$msg\" with title \"Syncthing Watchdog\" sound name \"Basso\"" 2>/dev/null || true
    # Also write to a status file for easy checking
    echo "STALLED: $msg ($(date))" > "$HOME/.syncthing-watchdog-status"
}

clear_alert() {
    echo "OK: Last check $(date)" > "$HOME/.syncthing-watchdog-status"
}

# Write current heartbeat
write_heartbeat() {
    local now
    now=$(date +%s)
    echo "$now" > "$HEARTBEAT_FILE"
    log "Wrote heartbeat: $now"
    printf '%s\n' "$now"
}

# Check whether Nimbini receives the heartbeat written by this run. Comparing
# against the previous heartbeat's age produced false alarms whenever the Mac
# woke from sleep, before Syncthing had a chance to send the new file.
check_nimbini_heartbeat() {
    local expected_timestamp="$1"
    local remote_file="/home/will/Forge/.syncthing-heartbeat-mac"
    local remote_timestamp
    local deadline

    deadline=$(( $(date +%s) + PROPAGATION_TIMEOUT_SECONDS ))

    while [ "$(date +%s)" -le "$deadline" ]; do
        remote_timestamp=$(ssh -o ConnectTimeout=5 "$NIMBINI_HOST" \
            "bat --style=plain --paging=never $remote_file" 2>/dev/null || true)

        if [[ "$remote_timestamp" =~ ^[0-9]+$ ]] && \
           [ "$remote_timestamp" -ge "$expected_timestamp" ]; then
            log "Heartbeat reached Nimbini: $remote_timestamp"
            clear_alert
            return 0
        fi

        sleep "$POLL_INTERVAL_SECONDS"
    done

    alert "Sync stalled: heartbeat $expected_timestamp did not reach Nimbini within ${PROPAGATION_TIMEOUT_SECONDS}s"
    # A detected sync problem is a monitoring result, not a watchdog process
    # failure. Exit successfully so launchd continues its StartInterval schedule.
    return 0
}

main() {
    mkdir -p "$(dirname "$LOG_FILE")"

    case "${1:-run}" in
        run)
            heartbeat=$(write_heartbeat)
            check_nimbini_heartbeat "$heartbeat"
            ;;
        status)
            if [ -f "$HOME/.syncthing-watchdog-status" ]; then
                cat "$HOME/.syncthing-watchdog-status"
            else
                echo "No status yet (watchdog hasn't run)"
            fi
            ;;
        logs)
            tail -50 "$LOG_FILE" 2>/dev/null || echo "No logs yet"
            ;;
        test)
            echo "Testing watchdog..."
            heartbeat=$(write_heartbeat)
            echo "Heartbeat written. Checking Nimbini..."
            check_nimbini_heartbeat "$heartbeat"
            if rg -q '^OK:' "$HOME/.syncthing-watchdog-status"; then
                echo "OK: Sync is healthy"
            else
                echo "ALERT: Sync appears stalled"
            fi
            ;;
        *)
            echo "Syncthing Sync Watchdog"
            echo ""
            echo "Usage: syncthing-sync-watchdog [command]"
            echo ""
            echo "Commands:"
            echo "  run     - Write heartbeat and check sync (default)"
            echo "  status  - Show current watchdog status"
            echo "  logs    - Show recent watchdog logs"
            echo "  test    - Run once with verbose output"
            ;;
    esac
}

main "$@"
