#!/usr/bin/env bash
# email-wez — open meli in a maximized WezTerm window (macOS).
#
# WezTerm has no single --maximize flag, so we use the "huge initial
# size" trick: set initial_cols and initial_rows absurdly high.
# WezTerm clamps to screen size, giving an effectively maximized window.
# This is the standard community idiom.
#
# --always-new-process ensures a fresh WezTerm instance rather than
# routing the command into an existing window via the multiplexer.
#
# Absolute path to the homebrew wezterm — the CLI binary spawns a sibling
# `wezterm-gui` from the same directory. ~/.local/bin/wezterm exists as a
# symlink but WITHOUT a wezterm-gui sibling, so a bare `wezterm` resolved
# by PATH can fail with "No such file or directory" when launching the
# GUI process. /opt/homebrew/bin/ has both symlinks and is brew-managed.
# Absolute path to meli too — when this script is invoked from Hammerspoon
# via hs.execute, the calling /bin/sh has only a minimal launchd PATH, so
# bare `meli` isn't findable by wezterm at spawn time. Wezterm then opens
# an empty window with meli failing to start (and possibly without
# foreground activation, since the spawned program crashed).
# Override `config.default_prog` for this invocation only. wezterm.lua
# sets default_prog = nushell so all normal wezterm windows get a nu
# shell. The `-- /opt/homebrew/bin/meli` argument after `start
# --always-new-process` was being IGNORED because the config-level
# default_prog won — wezterm spawned a nu shell window with no foreground
# meli (which presented as "empty WezTerm appears, no meli inside").
# Setting default_prog as a per-invocation `--config` override (Lua array
# syntax: curly braces, NOT JSON brackets) tells this specific wezterm
# instance to launch meli as its default program. Same outcome as
# `-- meli` would have given on a stock wezterm config.
exec /opt/homebrew/bin/wezterm \
  --config 'default_prog={"/opt/homebrew/bin/meli"}' \
  start \
  --always-new-process
