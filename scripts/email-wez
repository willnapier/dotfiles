#!/usr/bin/env bash
# email-wez — open meli (via zellij + email-meli layout) in a maximized
# WezTerm window (macOS).
#
# WezTerm has no single --maximize flag, so we use the "huge initial
# size" trick: set initial_cols and initial_rows absurdly high.
# WezTerm clamps to screen size, giving an effectively maximized window.
# This is the standard community idiom.
#
# --always-new-process ensures a fresh WezTerm instance rather than
# routing the command into an existing window via the multiplexer.
#
# Why zellij? — see ~/dotfiles/scripts/email for the full rationale.
# Short version: the email-meli layout backgrounds mail-status-watch,
# which updates the zellij tab name with last sync timestamps.

# Absolute path to the homebrew wezterm — the CLI binary spawns a sibling
# `wezterm-gui` from the same directory, so it must be invoked from a
# location that has both. ~/.local/bin/wezterm exists as a symlink but
# WITHOUT a wezterm-gui sibling, so a bare `wezterm` resolved by PATH
# can fail with "No such file or directory" when launching the GUI
# process. /opt/homebrew/bin/ has both symlinks and is brew-managed.
exec /opt/homebrew/bin/wezterm \
  --config 'initial_cols=500' \
  --config 'initial_rows=200' \
  start \
  --always-new-process \
  -- zellij --layout email-meli
