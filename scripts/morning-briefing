#!/usr/bin/env bash
# morning-briefing — overnight-state digest, posted to MESSAGEBOARD.md
# Fired by ~/dotfiles/macos/launchd/com.williamnapier.morning-briefing.plist
# at 07:30 daily. Disable via:
#   launchctl bootout gui/$(id -u)/com.williamnapier.morning-briefing

set -u
PATH=/Users/williamnapier/.local/bin:/Users/williamnapier/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin
export PATH
export HOME=/Users/williamnapier

GMAIL_DIR="$HOME/Mail/gmail-mb"
GMAIL_LOG="$HOME/Library/Logs/mbsync-gmail.log"
MC_DIR="$HOME/.local/share/mailcurator"

now=$(date "+%Y-%m-%d %H:%M %Z")

# --- Gmail pull ---
# Soak counters are LIFETIME for the current log file. mbsync-gmail.log
# was created 2026-05-16 23:04 when the spike was retired; from a fresh
# log file the counts approximate "since spike retirement". If log
# rotation lands later, switch to a windowed count (past 24h).
if [ -d "$GMAIL_DIR" ]; then
  size=$(du -sh "$GMAIL_DIR" 2>/dev/null | awk '{print $1}')
  count=$(find "$GMAIL_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')
  last_tick=$(stat -f "%Sm" -t "%F %H:%M" "$GMAIL_LOG" 2>/dev/null)
  last_log=$(tail -3 "$GMAIL_LOG" 2>/dev/null | sed 's/^/    /')
  # ok_ticks counts EVERY mbsync run that completed cleanly — full mailcurator
  # passes (TOTAL line) plus runs where mailcurator skipped on inactivity
  # (Activity-check: skipping line). The earlier "only TOTAL" version
  # under-counted by an order of magnitude because mailcurator skips when no
  # machine has been active in 4h, which is typical overnight.
  full_ticks=$(grep -c '^\[mailcurator\] TOTAL' "$GMAIL_LOG" 2>/dev/null | tr -dc '0-9')
  skip_ticks=$(grep -c '^\[mailcurator\] Activity check: skipping' "$GMAIL_LOG" 2>/dev/null | tr -dc '0-9')
  ok_ticks=$(( ${full_ticks:-0} + ${skip_ticks:-0} ))
  dns_errs=$(grep -c 'Cannot resolve server' "$GMAIL_LOG" 2>/dev/null | tr -dc '0-9')
  auth_errs=$(grep -c 'pizauth show gmail failed' "$GMAIL_LOG" 2>/dev/null | tr -dc '0-9')
  gmail_section=$(printf -- "- Maildir: **%s** in %s\n- Last tick: %s\n- Soak (log lifetime): **%s** ok ticks (%s full + %s idle-skipped), **%s** DNS errs, **%s** auth errs\n- Tail:\n\n\`\`\`\n%s\n\`\`\`" \
    "$count messages" "$size" "$last_tick" "${ok_ticks:-0}" "${full_ticks:-0}" "${skip_ticks:-0}" "${dns_errs:-0}" "${auth_errs:-0}" "$last_log")
else
  gmail_section="- gmail-mb dir missing"
fi

# --- CI ---
if command -v gh >/dev/null 2>&1; then
  ci_lines=""
  for repo in willnapier/practiceforge willnapier/tm3-diary-capture; do
    line=$(gh run list --repo "$repo" --limit 1 --json conclusion,name,createdAt,headBranch \
      -q 'if length == 0 then "- '"$repo"': no workflow runs" else (.[0] | "- '"$repo"': \(.conclusion // "in progress") — \(.name) (\(.headBranch), \(.createdAt))") end' 2>/dev/null)
    [ -n "$line" ] && ci_lines="${ci_lines}${line}"$'\n'
  done
  if [ -n "$ci_lines" ]; then
    ci_section=$(printf '%s' "$ci_lines")
  else
    ci_section="- gh CLI returned nothing (auth or no recent runs)"
  fi
else
  ci_section="- gh not on PATH"
fi

# --- mailcurator ---
if [ -d "$MC_DIR" ]; then
  del_count=$(wc -l < "$MC_DIR/deletions.jsonl" 2>/dev/null | tr -d ' ')
  deliv_count=$(wc -l < "$MC_DIR/deliveries.jsonl" 2>/dev/null | tr -d ' ')
  recent_del=$(tail -3 "$MC_DIR/deletions.jsonl" 2>/dev/null | sed 's/^/    /')
  mc_section=$(printf -- "- deletions.jsonl lines: **%s**, deliveries.jsonl lines: **%s**\n- Last 3 deletions:\n\n\`\`\`\n%s\n\`\`\`" \
    "${del_count:-0}" "${deliv_count:-0}" "$recent_del")
else
  mc_section="- mailcurator dir missing"
fi

# --- Frontend audits ---
AUDIT_DIR="$HOME/Assistants/shared/audits"
audit_section=""
for proj in mailforge practiceforge; do
  f="$AUDIT_DIR/${proj}-frontend-audit-2026-05-02.md"
  if [ -f "$f" ]; then
    lines=$(wc -l < "$f" | tr -d ' ')
    audit_section="${audit_section}- ${proj}: **ready** (${lines} lines) — \`${f}\`"$'\n'
  else
    audit_section="${audit_section}- ${proj}: not yet written — agent may still be running"$'\n'
  fi
done
[ -z "$audit_section" ] && audit_section="- (no audit files configured)"

# --- Compose ---
body=$(cat <<EOF
**Morning briefing — generated $now**

### Gmail pull
$gmail_section

### Frontend audits (overnight)
$audit_section

### CI
$ci_section

### mailcurator
$mc_section
EOF
)

if command -v messageboard-edit >/dev/null 2>&1; then
  messageboard-edit insert "$body"
else
  printf "\n### %s — morning-briefing fallback\n\n%s\n\n---\n" "$now" "$body" >> "$HOME/Assistants/shared/MESSAGEBOARD.md"
fi
