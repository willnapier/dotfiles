#!/usr/bin/env bash
# morning-briefing — overnight-state digest, written to shared/MORNING-BRIEFING.md
# Fired by ~/dotfiles/macos/launchd/com.williamnapier.morning-briefing.plist
# at 07:30 daily. Disable via:
#   launchctl bootout gui/$(id -u)/com.williamnapier.morning-briefing

set -u
PATH=/Users/williamnapier/.local/bin:/Users/williamnapier/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin
export PATH
export HOME=/Users/williamnapier

GMAIL_DIR="$HOME/Mail/gmail-rs"
GMAIL_LOG="$HOME/Library/Logs/gmpull.log"
MC_DIR="$HOME/.local/share/mailcurator"

now=$(date "+%Y-%m-%d %H:%M %Z")

# --- Gmail pull (gmpull) ---
# gmpull (Gmail REST API puller) replaced the retired mbsync-gmail spike
# (2026-06-10); dir + log moved to gmail-rs / gmpull.log. Counters are LIFETIME
# for the current log file. If log rotation lands later, switch to a windowed
# count (past 24h).
if [ -d "$GMAIL_DIR" ]; then
  size=$(du -sh "$GMAIL_DIR" 2>/dev/null | awk '{print $1}')
  count=$(find "$GMAIL_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')
  last_tick=$(stat -f "%Sm" -t "%F %H:%M" "$GMAIL_LOG" 2>/dev/null)
  last_log=$(tail -4 "$GMAIL_LOG" 2>/dev/null | sed 's/^/    /')
  # gmpull logs one "incremental pull complete" per clean tick. mailcurator
  # (run via notmuch post-new, same stdout log) logs an "Activity check:
  # skipping" line when no machine has been active in 4h — typical overnight.
  # errors = any ERROR-level tracing line or a non-zero errored= in a progress line.
  pulls=$(grep -c 'incremental pull complete' "$GMAIL_LOG" 2>/dev/null | tr -dc '0-9')
  skip_ticks=$(grep -c '^\[mailcurator\] Activity check: skipping' "$GMAIL_LOG" 2>/dev/null | tr -dc '0-9')
  errs=$(grep -cE 'ERROR|errored=[1-9]' "$GMAIL_LOG" 2>/dev/null | tr -dc '0-9')
  gmail_section=$(printf -- "- Maildir: **%s** in %s\n- Last tick: %s\n- Soak (log lifetime): **%s** completed pulls, **%s** idle-skipped (mailcurator), **%s** errors\n- Tail:\n\n\`\`\`\n%s\n\`\`\`" \
    "$count messages" "$size" "$last_tick" "${pulls:-0}" "${skip_ticks:-0}" "${errs:-0}" "$last_log")
else
  gmail_section="- gmail-rs dir missing"
fi

# --- Package drift ---
# Cross-device package + version drift detector. SSHs to nimbini (with a
# 5s timeout — degrades to "unreachable" on weak networks). Added
# 2026-05-18 after the tailscale 1.88.1-on-disk / 1.96.5-running-daemon
# pattern that no existing monitoring would have caught.
if command -v package-drift-check >/dev/null 2>&1; then
  drift_section=$(package-drift-check 2>/dev/null || echo "- drift check exited non-zero")
else
  drift_section="- package-drift-check not on PATH"
fi

# --- CI ---
if command -v gh >/dev/null 2>&1; then
  ci_lines=""
  for repo in willnapier/practiceforge willnapier/tm3-diary-capture; do
    line=$(gh run list --repo "$repo" --limit 1 --json conclusion,name,createdAt,headBranch \
      -q 'if length == 0 then "- '"$repo"': no workflow runs" else (.[0] | "- '"$repo"': \(.conclusion // "in progress") — \(.name) (\(.headBranch), \(.createdAt))") end' 2>/dev/null)
    [ -n "$line" ] && ci_lines="${ci_lines}${line}"$'\n'
  done
  if [ -n "$ci_lines" ]; then
    ci_section=$(printf '%s' "$ci_lines")
  else
    ci_section="- gh CLI returned nothing (auth or no recent runs)"
  fi
else
  ci_section="- gh not on PATH"
fi

# --- mailcurator ---
if [ -d "$MC_DIR" ]; then
  del_count=$(wc -l < "$MC_DIR/deletions.jsonl" 2>/dev/null | tr -d ' ')
  deliv_count=$(wc -l < "$MC_DIR/deliveries.jsonl" 2>/dev/null | tr -d ' ')
  recent_del=$(tail -3 "$MC_DIR/deletions.jsonl" 2>/dev/null | sed 's/^/    /')
  mc_section=$(printf -- "- deletions.jsonl lines: **%s**, deliveries.jsonl lines: **%s**\n- Last 3 deletions:\n\n\`\`\`\n%s\n\`\`\`" \
    "${del_count:-0}" "${deliv_count:-0}" "$recent_del")
else
  mc_section="- mailcurator dir missing"
fi

# --- Frontend audits ---
AUDIT_DIR="$HOME/Assistants/shared/audits"
audit_section=""
for proj in mailforge practiceforge; do
  f="$AUDIT_DIR/${proj}-frontend-audit-2026-05-02.md"
  if [ -f "$f" ]; then
    lines=$(wc -l < "$f" | tr -d ' ')
    audit_section="${audit_section}- ${proj}: **ready** (${lines} lines) — \`${f}\`"$'\n'
  else
    audit_section="${audit_section}- ${proj}: not yet written — agent may still be running"$'\n'
  fi
done
[ -z "$audit_section" ] && audit_section="- (no audit files configured)"

# --- Compose ---
body=$(cat <<EOF
**Morning briefing — generated $now**

### Gmail pull
$gmail_section

### Package drift
$drift_section

### Frontend audits (overnight)
$audit_section

### CI
$ci_section

### mailcurator
$mc_section
EOF
)

# --- Write to own file, rolling 2-day window (NOT the messageboard) ---
# This digest is a DERIVED dashboard: every section above is a formatted view of
# a durable source (gmpull.log, package-drift-check, shared/audits/*,
# gh run list, mailcurator/*.jsonl). It is the sole record of nothing, so we keep
# only the two most-recent entries (today + yesterday) for a day-over-day glance.
# The <!-- briefing-entry --> marker is the awk delimiter between days.
BRIEF_FILE="$HOME/Assistants/shared/MORNING-BRIEFING.md"
marker="<!-- briefing-entry -->"
{
  printf '# Morning Briefing\n\n'
  printf '_Overwritten daily by `~/dotfiles/scripts/morning-briefing` — rolling 2-day window. A derived dashboard, not a record: every figure is a live view of a durable source (gmpull.log, package-drift-check, shared/audits/, gh run list, mailcurator/*.jsonl)._\n\n'
  printf '%s\n## %s\n\n%s\n' "$marker" "$now" "$body"
  if [ -f "$BRIEF_FILE" ]; then
    # carry forward only the most-recent prior entry (first marker block → becomes yesterday)
    awk -v m="$marker" '$0==m{c++; if(c==2) exit} c>=1{print}' "$BRIEF_FILE"
  fi
} > "$BRIEF_FILE.tmp" && mv -f "$BRIEF_FILE.tmp" "$BRIEF_FILE"
