#!/bin/bash
# Watch Downloads for TM3 diary HTML files and auto-capture to DayPages.
# Cross-platform: uses fswatch (macOS) or inotifywait (Linux).

SOURCE=~/Downloads

process_tm3() {
    for f in "$SOURCE"/*[Tt][Mm]3*.html "$SOURCE"/*[Tt][Mm]3*.htm; do
        if [ -f "$f" ]; then
            echo "$(date '+%Y-%m-%d %H:%M:%S') Found TM3 file: $(basename "$f")"
            tm3-diary-capture --latest
            return
        fi
    done
}

# Process any existing files on startup
process_tm3

echo "Watching $SOURCE for TM3 diary files..."

if command -v inotifywait &>/dev/null; then
    inotifywait -m -e create -e moved_to "$SOURCE" --format '%f' | while read -r filename; do
        if echo "$filename" | grep -iq 'tm3.*\.html\?$'; then
            sleep 2  # Let SingleFile finish writing
            process_tm3
        fi
    done
elif command -v fswatch &>/dev/null; then
    fswatch -0 "$SOURCE" | while IFS= read -r -d '' event; do
        if echo "$event" | grep -iq 'tm3.*\.html\?$'; then
            sleep 2  # Let SingleFile finish writing
            process_tm3
        fi
    done
else
    echo "ERROR: Neither inotifywait nor fswatch found"
    exit 1
fi
