#!/usr/bin/env bash
# cc-clinical — start Claude Code on the DPA'd Anthropic API path for clinical /
# PHI work.
#
# Why: bulk PHI-FREE development runs on the flat-rate Max subscription (just run
# `claude`). But reading real clinical DATA — special-category health data — must
# only transit Anthropic on the commercial **DPA + no-training API** path, never
# the consumer subscription (no DPA, may train). This wrapper sets
# ANTHROPIC_API_KEY from the existing note-drafting key in
# ~/.config/practiceforge/secrets.toml ([ai] api_key), so a clinical session
# shares the same DPA'd key/org.
#
# Companion: the `clinical-data-guard.sh` PreToolUse hook BLOCKS clinical-data
# reads whenever ANTHROPIC_API_KEY is unset (a normal Max session). So: do PHI
# work in `cc-clinical`; do everything else in plain `claude`.
#
# Usage: cc-clinical [any normal `claude` args]
set -euo pipefail

SECRETS="${HOME}/.config/practiceforge/secrets.toml"
CLINICAL_MARKER_DIR="${HOME}/.local/share/continuum/claude-clinical-sessions"

is_uuid() {
  [[ "$1" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]
}

register_clinical_session() {
  local session_id="$1"

  if ! install -d -m 700 "$CLINICAL_MARKER_DIR"; then
    echo "cc-clinical: cannot create the Continuum clinical-session registry; refusing to start." >&2
    exit 1
  fi

  # Register before Claude starts, closing the race in which the periodic sync
  # could otherwise see a new transcript before learning that it is clinical.
  if ! install -m 600 /dev/null "$CLINICAL_MARKER_DIR/$session_id"; then
    echo "cc-clinical: cannot register protected session $session_id; refusing to start." >&2
    exit 1
  fi
}

# Continuum identifies Claude sessions by UUID. Ensure every clinical launch has
# a known ID that can be registered before any PHI enters the session. Interactive
# resume selection (`--continue`, bare `--resume`) is therefore deliberately
# unavailable here; resume a clinical session by its explicit UUID instead.
declare -a CLAUDE_ARGS=("$@")
declare -a SESSION_IDS=()
explicit_session_id=""
resume_session_id=""
fork_session=false

for ((i = 0; i < ${#CLAUDE_ARGS[@]}; i++)); do
  arg="${CLAUDE_ARGS[$i]}"
  case "$arg" in
    --session-id)
      ((i += 1))
      if ((i >= ${#CLAUDE_ARGS[@]})) || ! is_uuid "${CLAUDE_ARGS[$i]}"; then
        echo "cc-clinical: --session-id requires an explicit lowercase UUID." >&2
        exit 2
      fi
      explicit_session_id="${CLAUDE_ARGS[$i]}"
      ;;
    --session-id=*)
      value="${arg#--session-id=}"
      if ! is_uuid "$value"; then
        echo "cc-clinical: --session-id requires an explicit lowercase UUID." >&2
        exit 2
      fi
      explicit_session_id="$value"
      ;;
    -r|--resume)
      ((i += 1))
      if ((i >= ${#CLAUDE_ARGS[@]})) || ! is_uuid "${CLAUDE_ARGS[$i]}"; then
        echo "cc-clinical: resume requires an explicit session UUID; the interactive picker is disabled." >&2
        exit 2
      fi
      resume_session_id="${CLAUDE_ARGS[$i]}"
      ;;
    --resume=*)
      value="${arg#--resume=}"
      if ! is_uuid "$value"; then
        echo "cc-clinical: resume requires an explicit session UUID; named/picker resume is disabled." >&2
        exit 2
      fi
      resume_session_id="$value"
      ;;
    -r?*)
      value="${arg#-r}"
      if ! is_uuid "$value"; then
        echo "cc-clinical: resume requires an explicit lowercase session UUID." >&2
        exit 2
      fi
      resume_session_id="$value"
      ;;
    -c|--continue)
      echo "cc-clinical: --continue is disabled because its session cannot be protected before launch; use --resume <UUID>." >&2
      exit 2
      ;;
    --fork-session)
      fork_session=true
      ;;
  esac
done

if [[ "$fork_session" == true && -z "$explicit_session_id" ]]; then
  echo "cc-clinical: --fork-session requires an explicit --session-id <UUID> for the protected fork." >&2
  exit 2
fi

if [[ -z "$explicit_session_id" && -z "$resume_session_id" ]]; then
  explicit_session_id="$(uuidgen | tr '[:upper:]' '[:lower:]')"
  CLAUDE_ARGS+=(--session-id "$explicit_session_id")
fi

[[ -n "$resume_session_id" ]] && SESSION_IDS+=("$resume_session_id")
[[ -n "$explicit_session_id" ]] && SESSION_IDS+=("$explicit_session_id")

for session_id in "${SESSION_IDS[@]}"; do
  register_clinical_session "$session_id"
done

if [ ! -f "$SECRETS" ]; then
  echo "cc-clinical: $SECRETS not found — cannot obtain the DPA'd API key." >&2
  exit 1
fi

# Pull api_key from the [ai] section. Take everything after the first '=' (so a
# key containing '=' survives), then strip surrounding whitespace/quotes.
KEY=$(awk '
  /^\[/ { insec = 0 }
  /^\[ai\]/ { insec = 1; next }
  insec && /^[[:space:]]*api_key[[:space:]]*=/ {
    sub(/^[^=]*=/, ""); gsub(/^[[:space:]"]+|[[:space:]"]+$/, ""); print; exit
  }' "$SECRETS")

if [ -z "${KEY:-}" ] || [[ "$KEY" != sk-* ]]; then
  echo "cc-clinical: could not read a valid [ai] api_key (sk-...) from $SECRETS." >&2
  exit 1
fi

export ANTHROPIC_API_KEY="$KEY"
echo "cc-clinical: DPA / no-training API session active — clinical-data reads are permitted here." >&2
exec claude "${CLAUDE_ARGS[@]}"
