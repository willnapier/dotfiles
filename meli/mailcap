# meli mailcap — controls what meli does when you press `m` on an attachment.
# Format: see mailcap(5). Simplest form is `mime/type; command %s; flags`.
#
# Deployed to ~/.config/meli/mailcap on both Mac and Linux.
#
# Custom flag (meli fork extension):
#   x-meli-pipe-message — meli pipes the parent envelope's FULL RFC822 bytes
#   to the helper on stdin instead of just the decoded part. Lets meliview
#   resolve cid: inline images in multipart/related messages. Requires the
#   patched meli at ~/.local/bin/meli; vanilla meli logs the flag as unknown
#   and falls through to default part-bytes behaviour.

# HTML body parts → meliview pipe (full envelope so cid: assets resolve).
text/html; meliview pipe; x-meli-pipe-message

# PDF attachments → open with system default (Preview on macOS, default PDF
# viewer on Linux). Faster than routing through meliview for PDFs since
# the system viewer is already what we'd hand off to.
application/pdf; open %s; copiousoutput=false
