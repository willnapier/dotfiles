<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.williamnapier.gmail-push-tags-watchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/williamnapier/.local/bin/gmail-push-tags-watchdog</string>
    </array>
    <!-- Health check fires every 30 min. The watchdog itself is silent
         when healthy; only fires NotificationCenter banners on detected
         problems. Companion to com.williamnapier.gmail-push-tags. -->
    <key>StartInterval</key>
    <integer>1800</integer>
    <key>RunAtLoad</key>
    <false/>
    <!-- PATH for `launchctl` and (Mac path) `osascript`. Both are in
         /usr/bin so the minimal launchd PATH is fine, but explicit > implicit. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/Users/williamnapier/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/williamnapier</string>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/williamnapier/Library/Logs/gmail-push-tags-watchdog.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/williamnapier/Library/Logs/gmail-push-tags-watchdog.log</string>
</dict>
</plist>
