#!/usr/bin/env bash
# notmuch post-new hook
# Runs automatically after every `notmuch new` (invoked by mail-sync every 15 min).
#
# Purpose: keep the inbox view self-maintaining by archiving messages that
# have aged past the 6-month window. Messages aren't deleted — they just
# lose the `inbox` tag, corresponding to Gmail's "Archive" action.
#
# Adding rules: drop `notmuch tag` lines below. Each is idempotent.
# Effects propagate to Gmail on the next mail-sync tick (push phase).

set -eu

# --- Rule 0: tag messages from the COHS Maildir source ---
# Any message under ~/Mail/cohs/ (mbsync from Microsoft 365) gets tagged `cohs`.
notmuch tag +cohs -- 'path:"cohs/**" and not tag:cohs'

# Per-folder tagging so Meli's cohs account can show them as separate mailboxes:
notmuch tag +inbox -- 'path:"cohs/INBOX/**" and tag:new'
notmuch tag +sent -- 'path:"cohs/Sent Items/**" and not tag:sent'
notmuch tag +drafts -- 'path:"cohs/Drafts/**" and not tag:drafts'
notmuch tag +archive -- 'path:"cohs/Archive/**" and not tag:archive'
notmuch tag +trash -- 'path:"cohs/Deleted Items/**" and not tag:trash'
notmuch tag +spam -- 'path:"cohs/Junk Email/**" and not tag:spam'

# --- Rule 1: age-based inbox pruning ---
# Any message still tagged `inbox` but older than 6 months leaves inbox.
# Applies continuously: as messages cross the 6M threshold, they age out.
notmuch tag -inbox -- 'tag:inbox and not date:6M..'

# --- Rule 2: mailcurator (per-sender policies) ---
# Runs the mailcurator Rust binary (reads ~/.config/mailcurator/policies.toml)
# applying sender-specific lifecycle rules. It selects messages by its own
# curator-<name>-seen / -extracted tags — NOT tag:new — so it still catches
# every new message whenever it runs.
#
# It's the heavy part of this hook (~9s), so two guards (2026-07-06) keep it
# from making every reindex slow:
#   1. MAILFORGE_FAST_REINDEX — set by mailforge's on-demand Refresh — skips
#      it entirely: the interactive refresh only needs new mail indexed +
#      tagged (done above); extraction catches up on the next background tick.
#   2. Throttle — run at most once per 120s, so back-to-back background
#      reindexes (gmpull 60s, mbsync ticks) don't stack 9s passes.
# Safe to fail — logs to stderr, never breaks the hook.
if command -v mailcurator >/dev/null 2>&1 && [ -z "${MAILFORGE_FAST_REINDEX:-}" ]; then
    mc_stamp="${TMPDIR:-/tmp}/mailcurator-lastrun"
    mc_now=$(date +%s)
    mc_last=$(cat "$mc_stamp" 2>/dev/null || echo 0)
    if [ "$((mc_now - mc_last))" -ge 120 ]; then
        printf '%s\n' "$mc_now" > "$mc_stamp" 2>/dev/null || true
        mailcurator run 2>&1 | sed 's/^/[mailcurator] /' || true
    fi
fi

# --- Rule 3.5: tag outgoing unsubscribe messages ---
# When MailForge sends an unsubscribe via the mailto-compose path,
# Gmail's SMTP saves a copy to the user's Sent folder. lieer pulls
# that back, notmuch indexes it, and notmuch's [new] config tags it
# `new;unread;inbox` by default. Without intervention, the from-self
# exception in MailForge's inbox query (which keeps PracticeForge
# OTPs visible) would also keep these unsub emails visible — clutter.
#
# Heuristic: outgoing messages whose To: matches common unsubscribe
# address patterns are themselves unsubscribe actions. Tag them
# `unsubscribed` (audit trail) and strip `inbox` so they vanish from
# the inbox view. The patterns below cover the vast majority of
# legitimate unsubscribe addresses; false positives would require an
# incoming email TO one of these patterns, which is vanishingly rare.
notmuch tag +unsubscribed -inbox -- \
    '(from:will@willnapier.com or from:will.napier@changeofharleystreet.com)
     and tag:new
     and (to:unsubscribe or to:unsub or to:list-unsubscribe or to:opt-out or to:remove-me)'

# --- Rule 3.6: file personal (Gmail) outgoing mail as Sent ---
# Gmail's SMTP saves a copy of every sent message to the Sent folder;
# gmailieer pulls it back. But the personal account is a FLAT Maildir (no
# "Sent" subfolder like COHS), so the path-based `+sent` rule in Rule 0
# can't catch it, and nothing else maps Gmail's SENT label to notmuch
# `sent`. Meanwhile notmuch's [new] config stamps every newly-indexed file
# `new;unread;inbox`. Net effect before this rule: outgoing personal mail
# (replies, forwards) wrongly landed in the Inbox as UNREAD and never
# appeared in the Sent view (`tag:sent and not path:cohs/**`). COHS is
# already handled by Rule 0's `cohs/Sent Items/**` path match.
#
# Fix: tag from-self personal mail `+sent`. For mail sent to OTHERS also
# strip `inbox`/`unread` — a reply/forward you sent shouldn't sit unread in
# your own inbox. Self-addressed mail (to:self — e.g. PracticeForge OTPs)
# KEEPS inbox/unread, matching the inbox view's deliberate from-self
# exception (see notmuch_db.rs inbox query). Keyed on `tag:new` so it only
# touches this tick's arrivals; idempotent. Must run before Rule 4 strips
# `new`. Effects propagate to Gmail on the next push (a sent-to-others
# message has no INBOX label there, so `-inbox` is a local-only correction;
# `-unread` marks the Sent copy read, which it is).
notmuch tag +sent -inbox -unread -- \
    'from:will@willnapier.com and tag:new and not path:"cohs/**"
     and not to:will@willnapier.com'
notmuch tag +sent -- \
    'from:will@willnapier.com and tag:new and not path:"cohs/**"
     and to:will@willnapier.com'

# --- Rule 4: strip the transient `new` tag ---
# notmuch's [new] config applies `new;unread;inbox` to every newly-
# indexed file. The `new` tag is supposed to be *transient* — used
# by earlier rules in this hook to find unprocessed mail, then
# stripped here so it doesn't accumulate forever. Without this step,
# `tag:new` grows monotonically and (historically) got pushed to
# Gmail by `gmi push` as a stray label. 2026-04-22 Gmail cleanup
# discovered 40,275 messages had a leaked `new` Gmail label — rooted
# in the absence of this line.
notmuch tag -new -- tag:new
