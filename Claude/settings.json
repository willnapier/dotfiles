{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash",
      "Agent",
      "WebFetch",
      "WebSearch",
      "Skill"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/ai-brief.nu render --harness claude-code --format claude-hook",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat ~/Assistants/shared/WILLIAM-BIOGRAPHICAL-PHILOSOPHICAL.md ~/Assistants/shared/WILLIAM-BIOGRAPHICAL-SOCIAL.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/legacy-tool-rewrite.sh",
            "statusMessage": "Checking tool usage..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ssh-rewrite.sh",
            "statusMessage": "Checking SSH syntax..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/prior-art-check.sh",
            "statusMessage": "Checking prior-art research..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/memory-platform-check.sh",
            "statusMessage": "Checking memory platform scope..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/clinical-data-guard.sh",
            "statusMessage": "Checking clinical-data footing..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/config-path-guard.sh",
            "statusMessage": "Checking file path..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/daypage-guard.sh",
            "statusMessage": "Checking DayPage safety..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/messageboard-guard.sh",
            "statusMessage": "Checking messageboard safety..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/clinical-write-guard.sh",
            "statusMessage": "Checking clinical file safety..."
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/clinical-data-guard.sh",
            "statusMessage": "Checking clinical-data footing..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_input.filePath // empty' | { read file_path; if [[ \"$file_path\" == *\"MESSAGEBOARD.md\" ]]; then API_KEY=$(syncthing cli config gui apikey get 2>/dev/null) && curl -s -X POST \"http://127.0.0.1:8384/rest/db/scan?folder=Assistants\" -H \"X-API-Key: $API_KEY\" >/dev/null 2>&1; fi; }"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/meli-mine-build.sh",
            "statusMessage": "Regenerating meli-mine man page..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/hollow-ack-check.sh",
            "statusMessage": "Checking for hollow acknowledgments..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/doc-gate-check.sh",
            "statusMessage": "Checking documentation gate..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/diagram-gate-check.sh",
            "statusMessage": "Checking diagram impact gate..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/nushell-syntax-check.sh",
            "statusMessage": "Checking nushell syntax..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "last30days@last30days-skill": true
  },
  "extraKnownMarketplaces": {
    "last30days-skill": {
      "source": {
        "source": "github",
        "repo": "mvanhorn/last30days-skill"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipWorkflowUsageWarning": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754246159316
  },
  "model": "opus"
}
